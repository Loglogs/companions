PORT=3000

# Secret used to verify incoming auth requests at POST /auth/token
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# ─── Model Configuration ─────────────────────────────────────────────────────
#
# Format 1 — Built-in providers (Anthropic, OpenAI, etc.):
#   DEFAULT_MODEL=anthropic:claude-sonnet-4-6
#   DEFAULT_MODEL=openai:gpt-4o
#
# Format 2 — Any OpenAI-compatible local server (Ollama, oMLX, LM Studio, etc.):
#   DEFAULT_MODEL=openai-compat:<baseUrl>:<modelId>
#   DEFAULT_MODEL_KEY=<api-key>    ← omit if the server has no auth
#
#   oMLX (port 8000):   openai-compat:http://localhost:8000/v1:<model-name>
#   Ollama (port 11434): openai-compat:http://localhost:11434/v1:<model-name>
#   LM Studio (1234):   openai-compat:http://localhost:1234/v1:<model-name>
#
# Per-mode overrides — uncomment to give Crew or Lenda their own model:
#   CREW_MODEL=openai-compat:http://localhost:8000/v1:Qwen3.6-35B-A3B-4bit
#   CREW_MODEL_KEY=qwer
#   TWEET_MODEL=openai-compat:http://localhost:8000/v1:Qwen3.6-35B-A3B-4bit
#   TWEET_MODEL_KEY=qwer
#
# Set one of the examples above, e.g.:
# DEFAULT_MODEL=anthropic:claude-sonnet-4-6
# DEFAULT_MODEL=openai-compat:http://localhost:11434/v1:llama3.2
# DEFAULT_MODEL_KEY=your-api-key-here   ← omit for keyless local servers

# ─── Anthropic API Key ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
